{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Wallscape",
  "version": "0.1.4",
  "identifier": "com.momo.wallscape-win",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1425",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Wallscape",
        "width": 1280,
        "height": 832,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost https: data: blob:; media-src 'self' asset: http://asset.localhost https: data: blob:; connect-src 'self' ipc: http://ipc.localhost http://localhost:1425 ws://localhost:1425; object-src 'none'; base-uri 'self'; frame-ancestors 'none'",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "publisher": "Wallscape",
    "license": "MIT",
    "category": "Utility",
    "shortDescription": "Native Windows wallpaper manager for images and videos.",
    "longDescription": "Wallscape manages local and Wallhaven wallpapers and can apply image or video wallpapers to the Windows desktop.",
    "resources": {
      "bundle/libmpv-2.dll": "libmpv-2.dll"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "skip"
      },
      "wix": {
        "bannerPath": "icons/installer/wix-banner.bmp",
        "dialogImagePath": "icons/installer/wix-dialog.bmp"
      },
      "nsis": {
        "headerImage": "icons/installer/nsis-header.bmp",
        "sidebarImage": "icons/installer/nsis-sidebar.bmp",
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico"
      }
    }
  }
}
