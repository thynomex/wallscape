    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tauri-apps/cli": "^2",
    "@types/node": "^22.19.21",
    "svelte": "^5.56.4",
    "svelte-check": "^4.0.0",
    "typescript": "~5.6.2",
    "vite": "^8.0.16"
  },
  "overrides": {
    "cookie": "0.7.2"
  }
